GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2

# Docker compose (backend connects to postgres service)
DATABASE_URL=postgresql+asyncpg://user:password@postgres:5432/ragdb

# Local dev with external postgres on host port 5433:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5433/ragdb
